---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { showBytes, rfcLink, verifBadgeClass, type Entry } from "../lib/wire";

export async function getStaticPaths() {
  const entries = await getCollection("entries");
  return entries.map((e) => ({
    params: { id: e.data.id },
    props: { entry: e.data as Entry },
  }));
}

const { entry } = Astro.props as { entry: Entry };
const ext = entry.ext ?? {};
const params = (ext.params ?? []) as any[];
const support = (ext.support_matrix ?? []) as any[];
const variants = (ext.variants ?? []) as any[];
const gotchas = (ext.gotchas ?? []) as string[];
const vectors = (ext.test_vectors ?? []) as any[];
const raw = (ext.raw_columns ?? null) as Record<string, string> | null;
const rfcs = (ext.reference_rfcs ?? []) as string[];
---

<BaseLayout title={`${entry.title} · wire`} description={entry.summary} jsonHref={`/${entry.id}.json`}>
  <p class="crumb">
    <a href="/">wire</a> / <a href={`/${entry.family}`}>{entry.family}</a> /
    <span>{entry.slug}</span>
  </p>

  <h1>{entry.title}</h1>
  <p style="margin:.6em 0 0">{entry.summary}</p>

  <div class="badges">
    <span class="badge"><b>{entry.family}</b></span>
    <span class="badge">kind <b>{entry.kind}</b></span>
    <span class="badge">status <b>{entry.status}</b></span>
    <span class={`badge ${verifBadgeClass(entry.verification)}`}>verification <b>{entry.verification}</b></span>
    <span class="badge">tier <b>{entry.tier}</b></span>
    <span class="badge dim">{entry.ext_type}</span>
  </div>

  {entry.aliases?.length ? (
    <p class="dim">aka: {entry.aliases.join(" · ")}</p>
  ) : null}

  {/* ── terminal-escape@1 ───────────────────────────────────────── */}
  {entry.ext_type === "terminal-escape@1" && (
    <>
      {ext.frame && (
        <section>
          <h2 class="section-h">frame</h2>
          <p>{ext.csi_or_osc} introducer: <span class="bytes">{showBytes(ext.frame.introducer_7bit)}</span> <span class="dim">{ext.frame.introducer_7bit_readable}</span></p>
          {ext.terminator_detail && (
            <p>terminator (<b>{ext.terminator}</b>): ST <span class="bytes">{showBytes(ext.terminator_detail.canonical_ST_7bit)}</span> · BEL <span class="bytes">{showBytes(ext.terminator_detail.alt_BEL)}</span></p>
          )}
        </section>
      )}
      {params.length > 0 && (
        <section>
          <h2 class="section-h">parameters / subcommands</h2>
          <table>
            <thead><tr><th>id</th><th>name</th><th>bytes (ST)</th><th>meaning</th></tr></thead>
            <tbody>
              {params.map((p: any) => (
                <tr id={(p.anchor ?? `#${p.id}`).replace("#", "")}>
                  <td><b>{p.id}</b></td>
                  <td>{p.name}</td>
                  <td class="bytes">{showBytes(p.byte_sequence_ST ?? p.byte_sequence_set ?? "")}</td>
                  <td>{p.meaning}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )}
      {support.length > 0 && (
        <section>
          <h2 class="section-h">support matrix</h2>
          <table>
            <thead><tr><th>terminal</th><th>level</th><th>since</th><th>notes</th></tr></thead>
            <tbody>
              {support.map((s: any) => (
                <tr><td>{s.terminal}</td><td class={s.level === "full" ? "accent" : "dim"}>{s.level}</td><td class="dim">{s.version_added}</td><td class="dim">{s.notes}</td></tr>
              ))}
            </tbody>
          </table>
        </section>
      )}
      {variants.length > 0 && (
        <section>
          <h2 class="section-h">variants</h2>
          <ul class="bare">{variants.map((v: any) => <li>{v.label}{v.entry_id ? <> — <a href={`/${v.entry_id}`}>{v.entry_id}</a></> : null} <span class="dim">{v.note}</span></li>)}</ul>
        </section>
      )}
      {gotchas.length > 0 && (
        <section>
          <h2 class="section-h">gotchas</h2>
          <ul class="bare">{gotchas.map((g: string) => <li>{g}</li>)}</ul>
        </section>
      )}
    </>
  )}

  {/* ── iana-registry-row@1 ─────────────────────────────────────── */}
  {entry.ext_type === "iana-registry-row@1" && (
    <section>
      <h2 class="section-h">registry record</h2>
      {ext.value !== undefined && <p>value: <b>{String(ext.value)}</b></p>}
      {rfcs.length > 0 && (
        <p>references: {rfcs.map((r: string, i: number) => { const l = rfcLink(r); return <>{i > 0 ? ", " : ""}{l ? <a href={l.href}>{l.label}</a> : r}</>; })}</p>
      )}
      {raw && (
        <table>
          <tbody>
            {Object.entries(raw).map(([k, v]) => (
              <tr><th style="white-space:nowrap">{k}</th><td>{String(v)}</td></tr>
            ))}
          </tbody>
        </table>
      )}
    </section>
  )}

  {/* ── encoding@1 ──────────────────────────────────────────────── */}
  {entry.ext_type === "encoding@1" && (
    <section>
      <h2 class="section-h">test vectors</h2>
      {ext.rfc && (() => { const l = rfcLink(String(ext.rfc)); return <p class="dim">{l ? <a href={l.href}>{l.label}</a> : ext.rfc}{ext.alphabet ? ` · alphabet: ${ext.alphabet}` : ""}</p>; })()}
      <table>
        <thead><tr><th>input</th><th></th><th>output</th><th>note</th></tr></thead>
        <tbody>
          {vectors.map((v: any) => (
            <tr>
              <td class="bytes">{showBytes(String(v.input))} <span class="dim">{v.input_form}</span></td>
              <td class="dim">→</td>
              <td class="bytes">{showBytes(String(v.output))} <span class="dim">{v.output_form}</span></td>
              <td class="dim">{v.note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  {/* ── identifier@1 ────────────────────────────────────────────── */}
  {entry.ext_type === "identifier@1" && (
    <section>
      <h2 class="section-h">identifier</h2>
      <p class="dim">spec: {ext.spec}</p>
      <div class="badges">
        {ext.length_bits !== undefined && <span class="badge">length <b>{ext.length_bits} bits</b></span>}
        {ext.sortable !== undefined && (
          <span class={`badge ${ext.sortable ? "ok" : "warn"}`}>{ext.sortable ? "sortable" : "not sortable"}</span>
        )}
        {ext.encoding && <span class="badge dim">{ext.encoding}</span>}
      </div>
      <p style="margin:.7em 0 .2em">example:</p>
      <p><code class="bytes copyable" data-copy={ext.example}>{ext.example}<button class="copybtn" type="button" data-copy-trigger title="copy">⧉ copy</button></code></p>
      {Array.isArray(ext.bit_layout) && ext.bit_layout.length > 0 && (
        <table>
          <thead><tr><th>field</th><th>bits</th><th>meaning</th></tr></thead>
          <tbody>
            {ext.bit_layout.map((b: any) => (
              <tr><td><b>{b.field}</b></td><td class="accent">{b.bits}</td><td>{b.meaning}</td></tr>
            ))}
          </tbody>
        </table>
      )}
      {Array.isArray(ext.notes) && ext.notes.length > 0 && (
        <ul class="bare">{ext.notes.map((nx: string) => <li class="dim">{nx}</li>)}</ul>
      )}
    </section>
  )}

  {/* ── file-signature@1 ────────────────────────────────────────── */}
  {entry.ext_type === "file-signature@1" && (
    <section>
      <h2 class="section-h">file signature</h2>
      <p>magic: <span class="bytes copyable" data-copy={ext.magic_hex}>{ext.magic_hex}<button class="copybtn" type="button" data-copy-trigger title="copy">⧉ copy</button></span>
        {ext.offset ? <span class="dim"> @ offset {ext.offset}</span> : <span class="dim"> @ offset 0</span>}</p>
      {ext.magic_ascii && <p>ascii: <span class="bytes">{ext.magic_ascii}</span></p>}
      {ext.trailer_hex && <p>trailer: <span class="bytes">{ext.trailer_hex}</span></p>}
      <div class="badges">
        {Array.isArray(ext.extensions) && ext.extensions.map((x: string) => <span class="badge">.{x}</span>)}
        {ext.mime && <span class="badge dim">{ext.mime}</span>}
      </div>
      {ext.spec && <p class="dim">spec: {ext.spec}</p>}
      {Array.isArray(ext.notes) && ext.notes.length > 0 && (
        <ul class="bare">{ext.notes.map((nx: string) => <li class="dim">{nx}</li>)}</ul>
      )}
    </section>
  )}

  {/* ── wire-format@1 ───────────────────────────────────────────── */}
  {entry.ext_type === "wire-format@1" && (
    <section>
      <h2 class="section-h">wire format</h2>
      <p class="dim">spec: {ext.spec}</p>
      {ext.summary && <p style="margin:.5em 0">{ext.summary}</p>}
      {Array.isArray(ext.structure) && ext.structure.length > 0 && (
        <table>
          <thead><tr><th>field</th><th>size</th><th>meaning</th></tr></thead>
          <tbody>
            {ext.structure.map((s: any) => (
              <tr><td><b>{s.field}</b></td><td class="accent" style="white-space:nowrap">{s.size}</td><td>{s.meaning}</td></tr>
            ))}
          </tbody>
        </table>
      )}
      {ext.example_hex && (
        <>
          <p style="margin:.7em 0 .2em">example:</p>
          <p><code class="bytes copyable" data-copy={ext.example_hex}>{ext.example_hex}<button class="copybtn" type="button" data-copy-trigger title="copy">⧉ copy</button></code></p>
          {ext.example_decoded && <p class="dim">{ext.example_decoded}</p>}
        </>
      )}
      {Array.isArray(ext.see) && ext.see.length > 0 && (
        <p>see: {ext.see.map((s: string, i: number) => <>{i > 0 ? " · " : ""}<a href={`/${s}`}>{s}</a></>)}</p>
      )}
      {Array.isArray(ext.notes) && ext.notes.length > 0 && (
        <ul class="bare">{ext.notes.map((nx: string) => <li class="dim">{nx}</li>)}</ul>
      )}
    </section>
  )}

  {/* ── unknown ext_type → raw JSON ─────────────────────────────── */}
  {!["terminal-escape@1", "iana-registry-row@1", "encoding@1", "identifier@1", "file-signature@1", "wire-format@1"].includes(entry.ext_type) &&
    Object.keys(ext).length > 0 && (
      <section><h2 class="section-h">ext</h2><pre>{JSON.stringify(ext, null, 2)}</pre></section>
    )}

  {/* ── provenance (always) ─────────────────────────────────────── */}
  <hr />
  <section>
    <h2 class="section-h">provenance</h2>
    <ul class="bare">
      <li>source: <a href={entry.source_url}>{entry.source_url}</a></li>
      <li class="dim">version: {entry.source_version}</li>
      <li class="dim">retrieved: {entry.retrieved_date} · updated: {entry.updated}</li>
    </ul>
    {entry.attribution?.length ? (
      <>
        <p class="dim">per-fact attribution:</p>
        <ul class="bare">
          {entry.attribution.map((a) => (
            <li><span class="accent">{a.claim_ref}</span> — <a href={a.source_url}>{a.source_url}</a> <span class="dim">{a.note}</span></li>
          ))}
        </ul>
      </>
    ) : null}
  </section>

  {entry.see_also?.length ? (
    <section>
      <h2 class="section-h">see also</h2>
      <ul class="bare">{entry.see_also.map((s) => <li><a href={`/${s}`}>{s}</a></li>)}</ul>
    </section>
  ) : null}

  <p class="dim" style="margin-top:2em">
    agent: <code class="copyable" data-copy={`curl -H 'accept: application/json' wire.phall.io/${entry.id}`}>curl -H 'accept: application/json' wire.phall.io/{entry.id}<button class="copybtn" type="button" data-copy-trigger title="copy curl command">⧉ copy</button></code>
    or <a class="jsonlink-copy" href={`/${entry.id}.json`} data-copy={`https://wire.phall.io/${entry.id}.json`}>/{entry.id}.json</a><button class="copybtn" type="button" data-copy-trigger data-copy-prev title="copy json url">⧉ copy</button>
  </p>

  <style>
    .copybtn {
      font: inherit;
      font-size: 0.82em;
      margin-left: 0.6ch;
      padding: 0 0.5ch;
      background: transparent;
      color: var(--color-dim, #6d6d72);
      border: 1px solid var(--color-rule, #26262b);
      border-radius: 2px;
      cursor: pointer;
      vertical-align: baseline;
      user-select: none;
      transition: color 0.1s, border-color 0.1s;
    }
    .copybtn:hover {
      color: var(--color-accent, #5cc9a7);
      border-color: var(--color-accent, #5cc9a7);
    }
    .copybtn.copied {
      color: var(--color-accent, #5cc9a7);
      border-color: var(--color-accent, #5cc9a7);
    }
    /* A small copy affordance auto-attached to every byte sequence. */
    .bytes .copybtn,
    code .copybtn {
      opacity: 0.55;
    }
    .bytes:hover .copybtn,
    code:hover .copybtn,
    .copybtn:focus-visible {
      opacity: 1;
    }
  </style>

  <script is:inline>
    (function () {
      function payloadFor(btn) {
        // explicit previous-sibling source (the .json link case)
        if (btn.hasAttribute("data-copy-prev")) {
          var prev = btn.previousElementSibling;
          if (prev) return prev.getAttribute("data-copy") || prev.textContent.trim();
        }
        // nearest ancestor/self carrying data-copy
        var host = btn.closest("[data-copy]");
        if (host) {
          var explicit = host.getAttribute("data-copy");
          if (explicit) return explicit;
          // textContent minus the button label
          var clone = host.cloneNode(true);
          clone.querySelectorAll(".copybtn").forEach(function (b) { b.remove(); });
          return clone.textContent.trim();
        }
        return "";
      }
      function flash(btn) {
        var label = btn.textContent;
        btn.textContent = "✓ copied";
        btn.classList.add("copied");
        setTimeout(function () {
          btn.textContent = label;
          btn.classList.remove("copied");
        }, 1100);
      }
      document.addEventListener("click", function (e) {
        var btn = e.target.closest && e.target.closest("[data-copy-trigger]");
        if (!btn) return;
        e.preventDefault();
        var text = payloadFor(btn);
        if (!text) return;
        var done = function () { flash(btn); };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(done, function () {
            fallbackCopy(text); done();
          });
        } else {
          fallbackCopy(text); done();
        }
      });
      function fallbackCopy(text) {
        var ta = document.createElement("textarea");
        ta.value = text;
        ta.setAttribute("readonly", "");
        ta.style.position = "absolute";
        ta.style.left = "-9999px";
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand("copy"); } catch (_) {}
        document.body.removeChild(ta);
      }
      // Auto-attach a copy affordance to every standalone byte sequence
      // that doesn't already have one (terminal-escape tables, encoding vectors).
      document.querySelectorAll(".bytes").forEach(function (el) {
        if (el.querySelector(".copybtn")) return;
        var raw = el.textContent.trim();
        if (!raw) return;
        if (!el.hasAttribute("data-copy")) el.setAttribute("data-copy", raw);
        var b = document.createElement("button");
        b.type = "button";
        b.className = "copybtn";
        b.setAttribute("data-copy-trigger", "");
        b.title = "copy bytes";
        b.textContent = "⧉";
        el.appendChild(b);
      });
    })();
  </script>
</BaseLayout>
