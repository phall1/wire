---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FAMILIES, verifBadgeClass, type Entry } from "../../lib/wire";

export async function getStaticPaths() {
  const entries = await getCollection("entries");
  const families = [...new Set(entries.map((e) => e.data.family))];
  return families.map((family) => ({
    params: { family },
    props: {
      family,
      items: entries
        .filter((e) => e.data.family === family)
        .map((e) => e.data as Entry)
        .sort((a, b) => a.slug.localeCompare(b.slug, undefined, { numeric: true })),
    },
  }));
}

const { family, items } = Astro.props as { family: string; items: Entry[] };
const blurb = FAMILIES[family]?.blurb ?? family;
---

<BaseLayout title={`${family} · wire`} description={`${blurb} — ${items.length} entries`} jsonHref={`/${family}/index.json`}>
  <p class="crumb"><a href="/">wire</a> / <span>{family}</span></p>
  <h1>{family}</h1>
  <p class="dim" style="margin:.4em 0 0">{blurb}</p>

  <input
    id="filter"
    class="q"
    type="search"
    placeholder={`filter ${items.length} ${family} entries…`}
    autocomplete="off"
    spellcheck="false"
    aria-label="filter entries"
    style="margin-top:1.2em"
  />
  <p class="count" id="count">{items.length} entries</p>

  <nav class="rows" id="rows">
    {items.map((e) => (
      <a
        class="row"
        href={`/${e.id}`}
        data-s={`${e.slug} ${e.title} ${(e.aliases ?? []).join(" ")}`.toLowerCase()}
      >
        <span class="slug">{e.slug}</span>
        <span class="ttl">{e.title}</span>
        <span class={`v ${verifBadgeClass(e.verification)}`}>
          {e.verification === "verified" ? "✓" : e.verification}
        </span>
      </a>
    ))}
  </nav>

  <script>
    const f = document.getElementById("filter") as HTMLInputElement;
    const rows = Array.from(document.querySelectorAll<HTMLAnchorElement>("#rows .row"));
    const count = document.getElementById("count")!;
    const total = rows.length;
    const render = () => {
      const q = f.value.toLowerCase().trim();
      let shown = 0;
      for (const r of rows) {
        const hit = !q || (r.dataset.s ?? "").includes(q);
        r.hidden = !hit;
        if (hit) shown++;
      }
      count.textContent = q ? `${shown} of ${total} entries` : `${total} entries`;
    };
    f.addEventListener("input", render);
    f.focus();
  </script>
</BaseLayout>
