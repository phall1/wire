---
// Command-palette global search. Opened with Cmd/Ctrl-K or `/` from anywhere,
// closed with Esc. Fetches /search-index.json lazily on first open, fuzzy-ranks
// by id/title/alias match, navigates on Enter. Vanilla TS, no dependencies.
// All styling is component-scoped; global.css is untouched.
---

<div id="palette" class="palette" hidden role="dialog" aria-modal="true" aria-label="search">
  <div class="palette-backdrop" data-close></div>
  <div class="palette-box" role="document">
    <div class="palette-input-row">
      <span class="palette-prompt" aria-hidden="true">&gt;</span>
      <input
        id="palette-input"
        class="palette-input"
        type="text"
        placeholder="search the wire…  (try: osc 133, 418, base64, AAAA)"
        autocomplete="off"
        autocapitalize="off"
        autocorrect="off"
        spellcheck="false"
        aria-label="search"
        aria-controls="palette-results"
        aria-autocomplete="list"
      />
    </div>
    <ul id="palette-results" class="palette-results" role="listbox" aria-label="results"></ul>
    <div class="palette-hint" aria-hidden="true">
      <span class="palette-keys">↑↓</span> navigate
      <span class="palette-sep">·</span>
      <span class="palette-keys">↵</span> open
      <span class="palette-sep">·</span>
      <span class="palette-keys">esc</span> close
    </div>
  </div>
</div>

<style>
  .palette[hidden] {
    display: none;
  }
  .palette {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 12vh 16px 16px;
  }
  .palette-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(6, 6, 8, 0.72);
    backdrop-filter: blur(1.5px);
  }
  .palette-box {
    position: relative;
    width: 100%;
    max-width: 640px;
    background: #0e0e10;
    border: 1px solid var(--color-accent, #5cc9a7);
    box-shadow: 0 0 0 1px rgba(92, 201, 167, 0.15), 0 24px 64px rgba(0, 0, 0, 0.6);
    font-family: var(
      --font-mono,
      ui-monospace,
      "JetBrains Mono",
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace
    );
    font-size: 13px;
    line-height: 1.55;
    display: flex;
    flex-direction: column;
    max-height: 72vh;
  }
  .palette-input-row {
    display: flex;
    align-items: baseline;
    gap: 1ch;
    padding: 10px 12px;
    border-bottom: 1px solid var(--color-rule, #26262b);
  }
  .palette-prompt {
    color: var(--color-accent, #5cc9a7);
    flex: 0 0 auto;
  }
  .palette-input {
    flex: 1 1 auto;
    min-width: 0;
    background: transparent;
    border: 0;
    outline: none;
    color: var(--color-fg, #d9d9dc);
    font: inherit;
    padding: 0;
  }
  .palette-input::placeholder {
    color: var(--color-dim, #6d6d72);
  }
  .palette-results {
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-y: auto;
    flex: 1 1 auto;
  }
  .palette-results:empty {
    display: none;
  }
  .palette-row {
    display: flex;
    align-items: baseline;
    gap: 1.5ch;
    padding: 5px 12px;
    cursor: pointer;
    border-left: 2px solid transparent;
    text-decoration: none;
    color: inherit;
  }
  .palette-row[aria-selected="true"] {
    background: #15151b;
    border-left-color: var(--color-accent, #5cc9a7);
  }
  .palette-row .pid {
    flex: 0 0 auto;
    color: var(--color-accent, #5cc9a7);
    white-space: nowrap;
  }
  .palette-row .pttl {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--color-dim, #6d6d72);
  }
  .palette-row .pfam {
    flex: 0 0 auto;
    color: var(--color-dim, #6d6d72);
    font-size: 11.5px;
    border: 1px solid var(--color-rule, #26262b);
    padding: 0 6px;
    white-space: nowrap;
  }
  .palette-empty {
    padding: 8px 12px;
    color: var(--color-dim, #6d6d72);
  }
  .palette-hint {
    padding: 7px 12px;
    border-top: 1px solid var(--color-rule, #26262b);
    color: var(--color-dim, #6d6d72);
    font-size: 11.5px;
    flex: 0 0 auto;
    user-select: none;
  }
  .palette-hint .palette-keys {
    color: var(--color-fg, #d9d9dc);
  }
  .palette-hint .palette-sep {
    color: var(--color-rule, #26262b);
    margin: 0 0.6ch;
  }
</style>

<script>
  interface Hit {
    id: string;
    title: string;
    summary: string;
    aliases: string[];
    family: string;
    kind: string;
  }

  const MAX_RESULTS = 30;

  const palette = document.getElementById("palette") as HTMLElement;
  const input = document.getElementById("palette-input") as HTMLInputElement;
  const results = document.getElementById("palette-results") as HTMLUListElement;

  let idx: Hit[] = [];
  let loaded = false;
  let loading = false;
  let current: Hit[] = [];
  let sel = 0;

  const esc = (s: string) =>
    s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c]!);

  function loadIndex(): void {
    if (loaded || loading) return;
    loading = true;
    fetch("/search-index.json")
      .then((r) => r.json())
      .then((d: Hit[]) => {
        idx = d;
        loaded = true;
        loading = false;
        render();
      })
      .catch(() => {
        loading = false;
      });
  }

  function score(h: Hit, terms: string[]): number {
    const hay = `${h.id} ${h.title} ${h.summary} ${h.aliases.join(" ")}`.toLowerCase();
    const idl = h.id.toLowerCase();
    const ttl = h.title.toLowerCase();
    const ali = h.aliases.join(" ").toLowerCase();
    let s = 0;
    for (const t of terms) {
      if (!hay.includes(t)) return -1;
      if (idl.includes(t)) s += 3;
      if (ttl.includes(t)) s += 2;
      if (ali.includes(t)) s += 1;
      s += 1;
    }
    return s;
  }

  function compute(): Hit[] {
    const terms = input.value.toLowerCase().trim().split(/\s+/).filter(Boolean);
    if (!terms.length) return [];
    return idx
      .map((h) => ({ h, s: score(h, terms) }))
      .filter((x) => x.s >= 0)
      .sort((a, b) => b.s - a.s)
      .slice(0, MAX_RESULTS)
      .map((x) => x.h);
  }

  function render(): void {
    current = compute();
    sel = 0;
    if (!input.value.trim()) {
      results.innerHTML = `<li class="palette-empty">type to search ${idx.length} entries…</li>`;
      return;
    }
    if (!current.length) {
      results.innerHTML = `<li class="palette-empty">no matches</li>`;
      return;
    }
    results.innerHTML = current
      .map(
        (h, i) =>
          `<li class="palette-row" role="option" id="palette-opt-${i}" aria-selected="${i === 0}" data-i="${i}">` +
          `<span class="pid">${esc(h.id)}</span>` +
          `<span class="pttl">${esc(h.title)}</span>` +
          `<span class="pfam">${esc(h.family)}</span>` +
          `</li>`,
      )
      .join("");
  }

  function paintSel(): void {
    const rows = results.querySelectorAll<HTMLElement>(".palette-row");
    rows.forEach((r, i) => {
      const on = i === sel;
      r.setAttribute("aria-selected", on ? "true" : "false");
      if (on) {
        input.setAttribute("aria-activedescendant", r.id);
        r.scrollIntoView({ block: "nearest" });
      }
    });
  }

  function move(delta: number): void {
    if (!current.length) return;
    sel = (sel + delta + current.length) % current.length;
    paintSel();
  }

  function go(): void {
    const h = current[sel];
    if (h) window.location.assign(`/${h.id}`);
  }

  function isOpen(): boolean {
    return !palette.hasAttribute("hidden");
  }

  function open(): void {
    if (isOpen()) return;
    palette.removeAttribute("hidden");
    loadIndex();
    render();
    // focus after un-hiding so the caret lands in the input
    requestAnimationFrame(() => input.focus());
  }

  function close(): void {
    if (!isOpen()) return;
    palette.setAttribute("hidden", "");
    input.value = "";
    results.innerHTML = "";
    input.removeAttribute("aria-activedescendant");
  }

  // Whether an element is a text-entry target we should not hijack `/` from.
  function isTyping(el: EventTarget | null): boolean {
    const node = el as HTMLElement | null;
    if (!node) return false;
    const tag = node.tagName;
    return (
      tag === "INPUT" ||
      tag === "TEXTAREA" ||
      tag === "SELECT" ||
      (node as HTMLElement).isContentEditable === true
    );
  }

  // Global open shortcuts.
  document.addEventListener("keydown", (e) => {
    // Cmd/Ctrl-K from anywhere.
    if ((e.metaKey || e.ctrlKey) && (e.key === "k" || e.key === "K")) {
      e.preventDefault();
      isOpen() ? close() : open();
      return;
    }
    // `/` opens — but never when the user is typing in some other field.
    if (e.key === "/" && !isOpen() && !isTyping(e.target) && !e.metaKey && !e.ctrlKey && !e.altKey) {
      e.preventDefault();
      open();
    }
  });

  // Statusline affordance click → open.
  document.addEventListener("click", (e) => {
    const trigger = (e.target as HTMLElement | null)?.closest("[data-palette-open]");
    if (trigger) {
      e.preventDefault();
      open();
    }
  });

  // In-palette interactions.
  input.addEventListener("input", render);

  input.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      e.preventDefault();
      close();
    } else if (e.key === "ArrowDown" || (e.ctrlKey && e.key === "n")) {
      e.preventDefault();
      move(1);
    } else if (e.key === "ArrowUp" || (e.ctrlKey && e.key === "p")) {
      e.preventDefault();
      move(-1);
    } else if (e.key === "Enter") {
      e.preventDefault();
      go();
    }
    // `/` typed inside the palette input is a literal slash — do not hijack.
  });

  results.addEventListener("mousemove", (e) => {
    const row = (e.target as HTMLElement | null)?.closest<HTMLElement>(".palette-row");
    if (!row) return;
    const i = Number(row.dataset.i);
    if (!Number.isNaN(i) && i !== sel) {
      sel = i;
      paintSel();
    }
  });

  results.addEventListener("click", (e) => {
    const row = (e.target as HTMLElement | null)?.closest<HTMLElement>(".palette-row");
    if (!row) return;
    const i = Number(row.dataset.i);
    if (!Number.isNaN(i)) {
      sel = i;
      go();
    }
  });

  // Backdrop click closes.
  palette.addEventListener("click", (e) => {
    if ((e.target as HTMLElement | null)?.hasAttribute("data-close")) close();
  });
</script>
