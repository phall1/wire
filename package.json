{
  "name": "wire",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "prebuild": "bun run scripts/prebuild.ts",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "gates": "bun run scripts/gates/run-all.ts",
    "test": "bun test",
    "ingest": "bun run ingest/cli.ts",
    "deploy": "bun run build && bunx wrangler pages deploy ./dist --project-name=wire --branch=main --commit-dirty=true",
    "deploy:preview": "bun run build && bunx wrangler pages deploy ./dist --project-name=wire --commit-dirty=true"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.0",
    "astro": "^6.3.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.0.0"
  }
}
